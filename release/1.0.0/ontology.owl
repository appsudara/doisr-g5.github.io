    <!-- https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#hasMember -->


    <owl:ObjectProperty rdf:about="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#hasMember">
        <rdfs:domain rdf:resource="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#Organization"/>
        <rdfs:range rdf:resource="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#Researcher"/>
        <rdfs:comment xml:lang="en">This movie property indicates that an Organization has a Researcher as member</rdfs:comment>
        <rdfs:label xml:lang="en">has member</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#hasMentor -->


    <owl:ObjectProperty rdf:about="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#hasMentor">
        <rdfs:domain rdf:resource="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#Student"/>
        <rdfs:range rdf:resource="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#Researcher"/>
        <rdfs:comment xml:lang="en">This property links the students to the researcher who mentored them</rdfs:comment>
        <rdfs:label xml:lang="en">has mentor</rdfs:label>
    </owl:ObjectProperty>



    <!-- https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#partOf -->


    <owl:ObjectProperty rdf:about="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#partOf">
        <rdfs:domain rdf:resource="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#Researcher"/>
        <rdfs:range rdf:resource="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#Organization"/>
        <rdfs:comment xml:lang="en">This property links instances from Researcher to Organization</rdfs:comment>
        <rdfs:label xml:lang="en">part of</rdfs:label>
    </owl:ObjectProperty>



