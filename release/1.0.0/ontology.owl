    <owl:DatatypeProperty rdf:about="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#foundedIn">
        <rdfs:domain rdf:resource="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0#Organization"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
