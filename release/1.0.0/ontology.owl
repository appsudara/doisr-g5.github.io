    <owl:Ontology rdf:about="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0">
        <owl:versionIRI rdf:resource="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0"/>
        <terms:abstract xml:lang="en">An movie vocabulary designed to illustrate how to publish vocabularies on the Web following the FAIR principles</terms:abstract>
        <dc:description xml:lang="en">This is an movie ontology to illustrate some of the annotations that should be included</dc:description>
        <dc:title xml:lang="en">The movie ontology</dc:title>
        <terms:created xml:lang="en">February 5th, 2020</terms:created>
        <terms:creator xml:lang="en">Tania Mobasser Aslfakouri,Fotis Chatzifotiadis,Alfonso Sudara Padilla </terms:creator>
        <terms:creator xml:lang="en">Alfonso Sudara Padilla </terms:creator>
        <terms:license rdf:resource="http://creativecommons.org/licenses/by/2.0/"/>
        <vann:preferredNamespacePrefix xml:lang="en">exo</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://appsudara.github.io/doisr-g5.github.io/release/1.0.0</vann:preferredNamespaceUri>
        <schema:citation xml:lang="en">Cite this vocabulary as: Tania Mobasser Aslfakouri, Alfonso Sudara Padilla, Fotis Chatzifotiadis, M. The movie ontology 1.0.1.</schema:citation>
        <rdfs:comment xml:lang="en">An movie vocabulary designed to illustrate how to publish vocabularies on the Web following the FAIR principles. This vocabulary describes three simple classes with 3 properties and a data property.</rdfs:comment>
        <owl:backwardCompatibleWith rdf:resource="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0"/>
        <owl:priorVersion rdf:resource="https://appsudara.github.io/doisr-g5.github.io/release/1.0.0"/>
        <owl:versionInfo xml:lang="en">1.0.1</owl:versionInfo>
    </owl:Ontology>



